---
layout: base.njk
title: Início
---
<div class="container flow">
  <section class="hero" style="text-align: center; margin: var(--space-xl) 0;">
    <h1 style="font-size: 3rem; margin-bottom: var(--space-xs);">{{ site.title }}</h1>
    <p style="font-size: 1.2rem; color: var(--c-secondary); font-style: italic;">{{ site.description }}</p>
  </section>

  <hr class="separator">

  <section class="recent-articles">
    <h2>Artigos Recentes</h2>
    <div class="flow">
      {% set count = 0 %}
      {% for post in collections.article | reverse %}
        {% if count < 3 %}
          <article class="post-preview">
            <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
            <p class="article-meta">
              {{ post.date | dateReadable }} 
              {% if post.data.author %} &bull; {{ post.data.author }}{% endif %}
            </p>
            {% if post.data.excerpt %}
              <p>{{ post.data.excerpt }}</p>
            {% endif %}
          </article>
          {% set count = count + 1 %}
        {% endif %}
      {% endfor %}
    </div>
    <div style="margin-top: var(--space-md);">
      <a href="/artigos/" class="btn btn-outline">Ver todos os artigos &rarr;</a>
    </div>
  </section>

  <hr class="separator">

  <section class="featured-pdfs">
    <h2>Catálogo em Destaque</h2>
    <div class="pdf-grid">
      {% for pdf in catalog.slice(0, 2) %}
        {% include "pdf-card.njk" %}
      {% endfor %}
    </div>
    <div style="margin-top: var(--space-md); text-align: center;">
      <a href="/catalogo/" class="btn btn-outline">Acessar catálogo completo &rarr;</a>
    </div>
  </section>
</div>
